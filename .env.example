# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# Azure OpenAI credentials (HKUST instance)
AZURE_OPENAI_API_KEY=
# NOTE: do NOT include /openai in the endpoint — the SDK appends it automatically.
AZURE_OPENAI_ENDPOINT=https://hkust.azure-api.net
AZURE_OPENAI_API_VERSION=2025-02-01-preview

# Deployment names — match whatever you have deployed in your Azure resource.
# Common HKUST defaults shown; change if yours differ.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EVAL_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
